                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "prometheus"
                    },
                    "group": "prometheus",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "expr": "sum(rate(http_requests_total[$__rate_interval]))",
                      "legendFormat": "__auto",
                      "range": true
                    },
                    "version": "v0"
                  },
                  "refId": "Overall RPS"
                }
              },
              {
                "kind": "PanelQuery",
                "spec": {
                  "hidden": false,
                  "query": {
                    "datasource": {
                      "name": "prometheus"
                    },
                    "group": "prometheus",
                    "kind": "DataQuery",
                    "spec": {
                      "editorMode": "code",
                      "expr": "sum(rate(http_requests_total[$__rate_interval])) by (path)",
                      "instant": false,
                      "legendFormat": "__auto",
                      "range": true
                    },
                    "version": "v0"
                  },
                  "refId": "by path, optional split"
                }
              }
            ],
            "queryOptions": {},
            "transformations": []
